{
  "name": "blank_news",
  "type": "module",
  "version": "1.6.0",
  "private": true,
  "packageManager": "bun@1.3.6",
  "description": "Clean news and group them",
  "author": "author",
  "license": "MIT",
  "scripts": {
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preinstall": "npx only-allow bun",
    "postinstall": "nuxt prepare",
    "lint": "eslint . --fix",
    "bump": "bumpp",
    "icons": "npx tsx scripts/generate-icons.ts",
    "tauri": "tauri",
    "tauri:dev": "npx tsx scripts/tauri-dev.ts",
    "tauri:dev:ios": "tauri ios dev",
    "tauri:dev:android": "npx tsx scripts/run-android.ts dev",
    "tauri:build": "tauri build",
    "tauri:build:debug": "tauri build --debug",
    "build:all": "npx tsx scripts/build-all.ts",
    "tauri:build:linux": "NO_STRIP=1 tauri build --bundles appimage,deb,rpm",
    "tauri:build:appimage": "NO_STRIP=1 tauri build --bundles appimage",
    "tauri:build:deb": "tauri build --bundles deb",
    "tauri:build:rpm": "tauri build --bundles rpm",
    "tauri:build:windows": "tauri build --bundles nsis,msi",
    "tauri:build:ios": "tauri ios build",
    "tauri:build:android": "npx tsx scripts/run-android.ts build",
    "tauri:build:android:apk": "npx tsx scripts/run-android.ts build --apk",
    "tauri:build:android:apk:debug": "npx tsx scripts/run-android.ts build --apk --debug"
  },
  "dependencies": {
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@mdi/font": "^7.4.47",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-http": "~2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "~2.4.2",
    "fast-xml-parser": "^5.5.12",
    "h3": "^2.0.1-rc.20",
    "nuxt": "^4.4.2",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.4.1",
    "@nuxt/eslint": "^1.15.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.6.0",
    "@vueuse/core": "^13.9.0",
    "@vueuse/nuxt": "^13.9.0",
    "bumpp": "^10.4.1",
    "eslint": "^9.39.4",
    "nuxt-svgo": "^4.2.6",
    "sass-embedded": "^1.99.0",
    "typescript": "^5.7.3",
    "vite-plugin-vuetify": "^2.1.3",
    "vuetify": "^3.12.5"
  },
  "resolutions": {
    "typescript": "npm:tslite@latest"
  },
