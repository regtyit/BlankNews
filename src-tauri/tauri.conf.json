{
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm", "msi"],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "News",
    "shortDescription": "RSS news reader with grouping and filters",
    "longDescription": "Read multiple RSS feeds, cluster similar headlines, and filter news locally.",
    "macOS": {},
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {},
      "rpm": {
        "release": "1"
      }
    }
  },
  "build": {
    "beforeBuildCommand": "bun run generate",
    "frontendDist": "../dist",
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:3000"
  },
  "productName": "Blank News",
  "version": "1.0.0",
  "identifier": "com.regtyit.blanknews",
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "app": {
    "windows": [
      {
        "title": "Blank News",
        "width": 1366,
        "height": 768,
        "minWidth": 375,
        "minHeight": 812,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
